@{
    Layout = null;
    ViewData["Title"] = "Coming Soon | The Assembly";
}

<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.7.2/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;900&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen flex items-center justify-center bg-[#0D0D0D] text-white/90 font-['Inter'] antialiased overflow-hidden">

    <div class="fixed top-[-10%] left-[-10%] w-[50%] h-[50%] bg-white/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="fixed bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-white/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="relative z-10 max-w-screen-md w-full px-10 py-20 text-center flex flex-col items-center gap-16 animate-in fade-in slide-in-from-bottom-4 duration-1000">
        
        <header class="space-y-6">
            <h1 class="text-5xl md:text-8xl font-black uppercase tracking-tighter italic scale-y-110">
                The Assembly
            </h1>
            <div class="h-px w-16 bg-white/20 mx-auto"></div>
        </header>

        <div class="space-y-4">
            <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.6em] text-white/30 block">
                Platform Under Construction
            </span>
            <h2 class="text-xl md:text-2xl font-light italic text-white/60 tracking-wider">
                Coming soon!!!...
            </h2>
        </div>

        <div class="w-full max-w-sm">
            <div class="group relative space-y-4">
                <p class="text-[9px] font-black uppercase tracking-[0.4em] opacity-20 group-hover:opacity-50 transition-opacity">
                    Launch Expected 2026
                </p>
                
                <form class="relative flex items-end border-b border-white/10 focus-within:border-white transition-colors duration-500 pb-3">
                    <input type="email"
                           placeholder="EMAIL@ASSEMBLY.COM"
                           class="bg-transparent border-none outline-none w-full text-xs tracking-[0.2em] font-light placeholder:text-white/10 uppercase" />
                    
                    <button type="button"
                            class="text-[10px] font-black uppercase tracking-widest hover:text-white transition-colors">
                        Notify
                    </button>
                </form>
            </div>
        </div>

        <footer class="pt-12 space-y-8">
            <div class="flex justify-center gap-8 opacity-20 hover:opacity-100 transition-opacity duration-700 text-sm">
                <a href="#"><i class="fa-brands fa-instagram"></i></a>
                <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
            </div>
            
            <a href="/" class="block text-[9px] font-black uppercase tracking-[0.5em] opacity-20 hover:opacity-100 transition-all border-b border-transparent hover:border-white/20 pb-1">
                Back to reality
            </a>
        </footer>
    </div>

</body>
</html>