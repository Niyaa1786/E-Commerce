<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The Assembly</title>
    
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.7.2/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
        font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col bg-base-100">

    <div class="bg-neutral text-neutral-content text-[10px] uppercase tracking-[0.3em] font-bold py-2 text-center">
        Free Shipping on orders over 500k
    </div>

    <div class="navbar bg-base-100 sticky top-0 z-50 border-b border-base-200 px-4 md:px-12 h-20">
        <div class="navbar-start">
            <div class="dropdown">
                <div role="button" class="btn btn-ghost lg:hidden">
                    <i class="fa-solid fa-bars"></i>
                </div>
                <ul class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52 font-bold uppercase tracking-tight">
                    <li><a>Women</a></li>
                    <li><a>Men</a></li>
                    <li><a>Kids</a></li>
                </ul>
            </div>
            <div class="hidden lg:flex">
                <ul class="menu menu-horizontal px-1 font-bold uppercase tracking-widest text-xs text-gray-500">
                    <li><a class="hover:text-black">Women</a></li>
                    <li><a class="hover:text-black">Men</a></li>
                    <li><a class="hover:text-black">Kids</a></li>
                </ul>
            </div>
        </div>

        <div class="navbar-center">
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 group cursor-pointer">
                <span class="text-xl font-black uppercase tracking-tighter italic">The Assembly</span>
            </a>
        </div>

        <div class="navbar-end gap-2">
            <button class="btn btn-ghost btn-circle">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
            <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-ghost btn-circle">
                    <div class="indicator">
                        <a asp-controller="Cart" asp-action="Index"><i class="fa-solid fa-cart-shopping text-lg"></i></a>
                    </div>
                </div>
            </div>
            <a asp-controller="Auth" asp-action="Login" class="btn btn-ghost btn-circle hidden md:flex">
                <i class="fa-regular fa-user"></i>
            </a>
        </div>
    </div>

    <main class="flex-grow">
        @RenderBody()
    </main>

    <footer class="footer p-10 bg-base-200 text-base-content">
        <aside>
            <p class="font-bold text-lg uppercase tracking-tighter italic">The Assembly</p>
            <p class="text-gray-500">Modern Essentials for a better life.<br />Established 2026</p>
        </aside>
        <nav>
            <h6 class="footer-title">Services</h6>
            <a class="link link-hover text-sm">Shipping</a>
            <a class="link link-hover text-sm">Returns</a>
            <a class="link link-hover text-sm">Contact</a>
        </nav>
        <nav>
            <h6 class="footer-title">Company</h6>
            <a class="link link-hover text-sm">About us</a>
            <a class="link link-hover text-sm">Design Philosophy</a>
            <a class="link link-hover text-sm">Press</a>
        </nav>
        <nav>
            <h6 class="footer-title">Legal</h6>
            <a class="link link-hover text-sm">Terms of use</a>
            <a class="link link-hover text-sm">Privacy policy</a>
        </nav>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>  