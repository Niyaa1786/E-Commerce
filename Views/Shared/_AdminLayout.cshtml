<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dashboard | The Assembly</title>

    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.7.2/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body { font-family: 'Inter', sans-serif; }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #d1d1d1; }
    </style>
</head>
<body class="bg-base-100 text-neutral antialiased">

    <div class="drawer lg:drawer-open">
        <input id="admin-drawer" type="checkbox" class="drawer-toggle" />
        
        <div class="drawer-content flex flex-col min-h-screen bg-base-200/50">
            
            <div class="navbar bg-base-100 border-b border-base-200 px-4 md:px-8 h-16 sticky top-0 z-30">
                <div class="flex-none lg:hidden">
                    <label for="admin-drawer" class="btn btn-ghost btn-square">
                        <i class="fa-solid fa-bars-staggered"></i>
                    </label>
                </div>
                
                <div class="flex-1">
                    <h2 class="text-[11px] font-black uppercase tracking-[0.2em] hidden md:block">
                        @ViewData["Title"]
                    </h2>
                </div>

                <div class="flex-none gap-4">
                    <button class="btn btn-ghost btn-circle btn-sm">
                        <div class="indicator">
                            <i class="fa-regular fa-bell"></i>
                            <span class="badge badge-neutral badge-xs indicator-item"></span>
                        </div>
                    </button>
                    
                    <div class="dropdown dropdown-end">
                        <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar online">
                            <div class="w-8 rounded-full ring ring-base-300 ring-offset-base-100 ring-offset-2">
                                <img src="https://ui-avatars.com/api/?name=Admin+Assembly&background=0D0D0D&color=fff" />
                            </div>
                        </div>
                        <ul tabindex="0" class="mt-3 z-[1] p-2 shadow-xl menu menu-sm dropdown-content bg-base-100 w-52 border border-base-200">
                            <li class="menu-title uppercase text-[10px] tracking-widest opacity-50">Manage Account</li>
                            <li><a>Profile Settings</a></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm" class="inline">
                                <button type="submit" class="text-error">
                                    Logout
                                </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <main class="p-4 md:p-8 animate-in fade-in duration-500">
                @RenderBody()
            </main>

        </div>

        <div class="drawer-side z-40">
            <label for="admin-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
            <aside class="w-72 min-h-screen bg-base-100 border-r border-base-200">
                <div class="h-20 flex items-center px-8 border-b border-base-200">
                    <a asp-controller="Home" asp-action="Index" class="text-xl font-black uppercase tracking-tighter italic">
                        The Assembly <span class="text-[8px] tracking-normal not-italic font-medium opacity-50 ml-1">ADMIN</span>
                    </a>
                </div>

                <div class="p-6">
                    <ul class="menu p-0 gap-2">
                        <li class="menu-title text-[10px] uppercase tracking-[0.3em] font-black opacity-40 mb-2">Main Menu</li>
                        
                        <li>
                            <a asp-action="Index" class="active:bg-neutral flex items-center gap-4 py-3 px-4 font-semibold text-sm transition-all rounded-none hover:bg-base-200">
                                <i class="fa-solid fa-chart-line w-5"></i> Dashboard
                            </a>
                        </li>

                        <li class="mt-4">
                            <details open>
                                <summary class="font-black text-[10px] uppercase tracking-[0.3em] opacity-40 py-2">Catalog</summary>
                                <ul class="mt-2 gap-1 before:bg-base-300">
                                    <li><a asp-controller="Product" asp-action="Index" class="py-2 text-sm rounded-none">Products</a></li>
                                    <li><a asp-controller="Category" asp-action="Index" class="py-2 text-sm rounded-none">Categories</a></li>
                                    <li><a asp-controller="ProductVariant" asp-action="Index" class="py-2 text-sm rounded-none">Inventory</a></li>
                                </ul>
                            </details>
                        </li>

                        <li class="mt-2">
                            <a asp-controller="Order" asp-action="Index" class="flex items-center justify-between py-3 px-4 font-semibold text-sm transition-all rounded-none hover:bg-base-200">
                                <div class="flex items-center gap-4">
                                    <i class="fa-solid fa-bag-shopping w-5"></i> Orders
                                </div>
                                <span class="badge badge-neutral badge-sm font-bold">12</span>
                            </a>
                        </li>

                        <li>
                            <a asp-controller="User" asp-action="Index" class="flex items-center gap-4 py-3 px-4 font-semibold text-sm transition-all rounded-none hover:bg-base-200">
                                <i class="fa-solid fa-users w-5"></i> Customers
                            </a>
                        </li>

                        <li class="menu-title text-[10px] uppercase tracking-[0.3em] font-black opacity-40 mt-8 mb-2">System</li>
                        
                        <li>
                            <a asp-controller="Home" asp-action="InProgress" class="flex items-center gap-4 py-3 px-4 font-semibold text-sm transition-all rounded-none hover:bg-base-200">
                                <i class="fa-solid fa-sliders w-5"></i> Settings
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="absolute bottom-0 w-full p-6 border-t border-base-200 bg-base-50">
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-success animate-pulse"></div>
                        <span class="text-[10px] font-bold uppercase tracking-widest opacity-50">Server: Stable</span>
                    </div>
                </div>
            </aside>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>