@model E_Commerce.Models.Products.Product
@{
    ViewData["Title"] = Model.Name;
    Layout = "_Layout";
}

<div class="bg-white min-h-screen font-['Inter'] antialiased text-slate-900 pt-20">
    <div class="max-w-[1400px] mx-auto px-6 py-12">
        
        <nav class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.3em] opacity-40 mb-12">
            <a href="/" class="hover:text-emerald-600 transition-colors">Trang chủ</a>
            <span>/</span>
            <a href="#" class="hover:text-emerald-600">@Model.Category?.Name</a>
            <span>/</span>
            <span class="text-slate-900">@Model.Name</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            
            <div class="lg:col-span-7 space-y-6">
                <div class="relative aspect-[3/4] overflow-hidden bg-slate-50 rounded-3xl border border-slate-100 group">
                    <img id="mainImage" src="@Model.ImageUrl" alt="@Model.Name" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                    
                    <button class="absolute top-6 right-6 w-12 h-12 bg-white/80 backdrop-blur-md rounded-full flex items-center justify-center shadow-sm hover:bg-white transition-all">
                        <i class="fa-solid fa-expand text-slate-600"></i>
                    </button>
                </div>
                
                <div class="grid grid-cols-4 gap-4">
                    <div class="aspect-square rounded-xl overflow-hidden border-2 border-emerald-500 cursor-pointer">
                        <img src="@Model.ImageUrl" class="w-full h-full object-cover" />
                    </div>
                </div>
            </div>

            <div class="lg:col-span-5 space-y-10 lg:sticky lg:top-32 h-fit">
                
                <div class="space-y-4">
                    <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-none">
                        @Model.Name
                    </h1>
                    <div class="flex items-baseline gap-4">
                        <span id="displayPrice" class="text-3xl font-bold text-slate-900">
                            @(Model.ProductVarients?.FirstOrDefault()?.Price.ToString("N0") ?? "---")đ
                        </span>
                    </div>
                </div>

                <div class="h-[1px] bg-slate-100 w-full"></div>

                <div class="space-y-8">
                    <div class="space-y-4">
                        <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400">Màu sắc</h4>
                        <div class="flex gap-3">
                            @foreach (var variant in Model.ProductVarients?.Select(v => v.Color).Distinct())
                            {
                                <button class="px-6 py-2 border border-slate-200 rounded-full text-[11px] font-bold hover:border-slate-900 transition-all uppercase tracking-widest">
                                    @variant
                                </button>
                            }
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400">Kích cỡ</h4>
                            <button class="text-[9px] font-bold uppercase tracking-widest text-emerald-600 underline">Hướng dẫn chọn size</button>
                        </div>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var variant in Model.ProductVarients?.Select(v => v.Size).Distinct())
                            {
                                <button class="w-14 h-14 flex items-center justify-center border border-slate-200 rounded-xl text-xs font-black hover:bg-slate-900 hover:text-white transition-all uppercase">
                                    @variant
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <div class="pt-6 flex gap-4">
                    <div class="w-32 h-14 border border-slate-200 rounded-2xl flex items-center justify-between px-4">
                        <button type="button" class="text-slate-400 hover:text-slate-900 transition-colors"><i class="fa-solid fa-minus"></i></button>
                        <span class="font-bold">1</span>
                        <button type="button" class="text-slate-400 hover:text-slate-900 transition-colors"><i class="fa-solid fa-plus"></i></button>
                    </div>

                    <form asp-controller="Cart" asp-action="Add" method="post" class="flex-1">
                        <input type="hidden" name="ProductVarientId" value="@Model.ProductVarients?.FirstOrDefault()?.Id" />
                        <input type="hidden" name="Quantity" value="1" />
        
                        <button type="submit" class="w-full h-14 bg-emerald-600 hover:bg-emerald-700 text-white rounded-2xl font-black uppercase tracking-[0.2em] text-[11px] shadow-xl shadow-emerald-200 transition-all active:scale-95">
                            Thêm vào giỏ hàng
                        </button>
                    </form>
                </div>

                <div class="pt-10 border-t border-slate-100">
                    <div class="collapse collapse-plus bg-transparent rounded-none">
                        <input type="radio" name="my-accordion-3" checked="checked" />
                        <div class="collapse-title px-0 text-[11px] font-black uppercase tracking-widest">Mô tả sản phẩm</div>
                        <div class="collapse-content px-0">
                            <p class="text-sm text-slate-500 leading-relaxed font-medium">@Model.Description</p>
                        </div>
                    </div>
                    <div class="collapse collapse-plus bg-transparent border-t border-slate-50 rounded-none">
                        <input type="radio" name="my-accordion-3" />
                        <div class="collapse-title px-0 text-[11px] font-black uppercase tracking-widest">Chính sách vận chuyển</div>
                        <div class="collapse-content px-0 text-sm text-slate-500 font-medium">
                            Miễn phí vận chuyển cho đơn hàng từ 1,000,000đ. Giao hàng trong 2-3 ngày làm việc.
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>