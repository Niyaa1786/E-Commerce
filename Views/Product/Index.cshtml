@model IEnumerable<E_Commerce.Models.Products.Product>
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <span class="text-[10px] uppercase tracking-[0.4em] font-black opacity-30 block mb-2">Kho hàng / Inventory</span>
            <h1 class="text-4xl font-black uppercase tracking-tighter italic">Sản phẩm</h1>
        </div>
        <a asp-action="Create" class="btn btn-neutral rounded-none h-12 px-8 uppercase tracking-[0.2em] text-[10px] font-black">
            + Thêm sản phẩm mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-none border-none py-3 text-[10px] font-black uppercase tracking-widest text-white shadow-lg animate-in fade-in slide-in-from-top-2">
            <i class="fa-solid fa-check"></i> @TempData["Success"]
        </div>
    }

    <div class="bg-white border border-gray-100 shadow-[0_1px_3px_rgba(0,0,0,0.02)] overflow-hidden">
        <div class="overflow-x-auto">
            <table class="table w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-100 text-[9px] uppercase tracking-[0.3em] font-black text-black/30">
                        <th class="py-6 px-8">Ảnh</th>
                        <th>Thông tin sản phẩm</th>
                        <th>Phân loại</th>
                        <th>Biến thể</th>
                        <th class="text-right px-8">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-[11px] font-bold uppercase tracking-widest">
                    @foreach (var item in Model)
                    {
                        <tr class="border-b border-gray-50">
                            <td class="px-8">
                                <div class="w-12 h-16 bg-gray-100 overflow-hidden border border-gray-100">
                                    <img src="@item.ImageUrl" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" onerror="this.src='https://placehold.co/400x600?text=NO+IMAGE'" />
                                </div>
                            </td>
                            <td>
                                <div class="space-y-1">
                                    <div class="text-black italic">@item.Name</div>
                                    <div class="text-[9px] opacity-30 font-black tracking-tighter lowercase line-clamp-1 max-w-[200px]">@item.Description</div>
                                </div>
                            </td>
                            <td class="opacity-40">@item.Category?.Name</td>
                            <td>
                                <span class="badge badge-outline rounded-none border-gray-200 text-[9px] font-black px-3">
                                    @item.ProductVarients?.Count BIẾN THỂ
                                </span>
                            </td>
                            <td class="text-right px-8 space-x-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="hover:text-black transition-colors opacity-30 hover:opacity-100">SỬA</a>
                                
                                <label for="delete-@item.Id" class="text-error opacity-30 hover:opacity-100 cursor-pointer transition-opacity">XÓA</label>
                                
                                <input type="checkbox" id="delete-@item.Id" class="modal-toggle" />
                                <div class="modal">
                                    <div class="modal-box rounded-none border border-gray-100 bg-white">
                                        <h3 class="font-black text-[10px] uppercase tracking-[0.4em] mb-4 text-left text-error">Xác nhận xóa</h3>
                                        <p class="text-sm normal-case font-medium text-gray-400 text-left">Bạn muốn xóa sản phẩm "@item.Name"?</p>
                                        <div class="modal-action">
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                                <button type="submit" class="btn btn-neutral btn-sm rounded-none uppercase text-[10px] tracking-widest px-6">Đồng ý</button>
                                            </form>
                                            <label for="delete-@item.Id" class="btn btn-ghost btn-sm rounded-none uppercase text-[10px] tracking-widest">Hủy</label>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>