@model IEnumerable<E_Commerce.DTOs.CategoryDTO.CategoryResponse>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <span class="text-[10px] uppercase tracking-[0.4em] font-black opacity-40 block mb-2">Catalog Management</span>
            <h1 class="text-4xl font-black uppercase tracking-tighter italic">Categories</h1>
        </div>
        <a asp-action="Create" class="btn btn-neutral rounded-none h-12 px-8 uppercase tracking-widest text-[11px] font-black shadow-lg shadow-neutral/20">
            + New Category
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-none border-none py-3 text-[11px] font-bold uppercase tracking-widest text-white shadow-xl animate-in fade-in slide-in-from-top-2">
            <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    <div class="bg-base-100 border border-base-200 shadow-sm overflow-hidden animate-in fade-in duration-700">
        <div class="overflow-x-auto">
            <table class="table table-zebra w-full">
                <thead>
                    <tr class="border-b border-base-200 text-[10px] uppercase tracking-[0.2em] font-black text-neutral-400">
                        <th class="py-6 px-8">ID</th>
                        <th>Category Name</th>
                        <th class="text-right px-8">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-sm font-semibold">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-base-200/50 transition-colors border-b border-base-100 last:border-0">
                            <td class="px-8 font-mono opacity-40">#@item.Id</td>
                            <td>
                                <span class="uppercase tracking-widest text-[12px]">@item.Name</span>
                            </td>
                            <td class="text-right px-8 space-x-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-ghost btn-xs rounded-none border-b border-neutral/20 hover:border-neutral">
                                    Edit
                                </a>
                                
                                <label for="delete-modal-@item.Id" class="btn btn-ghost btn-xs text-error rounded-none border-b border-error/20 hover:border-error">
                                    Delete
                                </label>

                                <input type="checkbox" id="delete-modal-@item.Id" class="modal-toggle" />
                                <div class="modal modal-bottom sm:modal-middle">
                                    <div class="modal-box bg-base-100 rounded-none border border-base-200 shadow-2xl text-left">
                                        <h3 class="font-black text-[11px] uppercase tracking-[0.4em] mb-4">Confirm Deletion</h3>
                                        <p class="text-sm text-neutral-500">Bạn có chắc chắn muốn xóa danh mục <span class="font-bold text-black">"@item.Name"</span>? Hành động này không thể hoàn tác.</p>
                                        <div class="modal-action">
                                            <label for="delete-modal-@item.Id" class="btn btn-ghost btn-sm rounded-none uppercase text-[10px] tracking-widest">Hủy</label>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-error btn-sm rounded-none uppercase text-[10px] tracking-widest text-white px-6">Xóa ngay</button>
                                            </form>
                                        </div>
                                    </div>
                                    <label class="modal-backdrop" for="delete-modal-@item.Id">Close</label>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="py-20 text-center opacity-30 italic tracking-widest text-xs">
                                Chưa có danh mục nào được khởi tạo.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>