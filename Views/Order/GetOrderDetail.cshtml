@model IEnumerable<E_Commerce.Models.Orders.OrderItem>
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="bg-white min-h-screen pt-28 pb-20 font-['Inter'] antialiased">
    <div class="max-w-[1000px] mx-auto px-6">
        
        <div class="flex items-center justify-between mb-16">
            <a href="@Url.Action("GetAllOrders")" class="text-[10px] font-black uppercase tracking-widest text-slate-300 hover:text-slate-900 transition-all flex items-center gap-2">
                <i class="fa-solid fa-arrow-left"></i> Quay lại
            </a>
            <h2 class="text-sm font-black uppercase tracking-[0.3em] text-slate-900">Thông tin sản phẩm</h2>
        </div>

        <div class="space-y-8">
            @foreach (var item in Model)
            {
                <div class="flex items-center gap-8 border-b border-slate-50 pb-8">
                    @* Nếu OrderItem có chứa ImageUrl, hãy hiển thị ở đây *@
                    <div class="w-20 h-24 bg-slate-50 rounded-xl overflow-hidden shrink-0">
                        <img src="@item.ProductVarient?.Product?.ImageUrl" class="w-full h-full object-cover" />
                    </div>

                    <div class="flex-1 space-y-1">
                        <h3 class="text-sm font-black uppercase tracking-tight text-slate-800">
                            @item.ProductVarient?.Product?.Name
                        </h3>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                            @item.ProductVarient?.Color / @item.ProductVarient?.Size
                        </p>
                        <p class="text-[11px] font-bold text-slate-500 pt-2">Số lượng: @item.Quantity</p>
                    </div>

                    <div class="text-right">
                        <p class="text-sm font-black text-slate-900">@item.UnitPrice.ToString("N0")đ</p>
                        <p class="text-[10px] font-bold text-emerald-500 mt-1 uppercase">Thành tiền: @((item.Quantity * item.UnitPrice).ToString("N0"))đ</p>
                    </div>
                </div>
            }
        </div>

        <div class="mt-16 bg-slate-50 p-10 rounded-[2.5rem] flex flex-col md:flex-row justify-between items-center gap-8">
            <div class="text-center md:text-left">
                <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Trạng thái xử lý</p>
                <p class="text-sm font-black uppercase tracking-widest text-amber-600 italic">Đang chờ xác nhận...</p>
            </div>
            <div class="text-center md:text-right">
                <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Tổng cộng toàn đơn</p>
                <p class="text-4xl font-black text-slate-900">@Model.Sum(x => x.Quantity * x.UnitPrice).ToString("N0")đ</p>
            </div>
        </div>
    </div>
</div>